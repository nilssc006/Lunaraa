// MARK: - Cycle

enum CyclePhase: String, Codable, CaseIterable, Identifiable {
    case menstruation
    case follicular
    case ovulation
    case luteal
    case unknown

    var id: String { rawValue }

    var title: String {
        switch self {
        case .menstruation: return "Menstruation"
        case .follicular: return "Follikelphase"
        case .ovulation: return "Ovulation"
        case .luteal: return "Lutealphase"
        case .unknown: return "Unbekannt"
        }
    }

    var emoji: String {
        switch self {
        case .menstruation: return "🌙"
        case .follicular: return "🌱"
        case .ovulation: return "🔥"
        case .luteal: return "💜"
        case .unknown: return "✨"
        }
    }

    var trainingHint: String {
        switch self {
        case .menstruation:
            return "Technik, moderate Lasten, sauberes Warm-up."
        case .follicular:
            return "Gute Phase für Progression und schwerere Sätze."
        case .ovulation:
            return "Hohe Leistungsfähigkeit möglich, sauber ausführen."
        case .luteal:
            return "Volumen leicht anpassen, Regeneration beachten."
        case .unknown:
            return "Starte konservativ und lerne aus Feedback."
        }
    }

    var nutritionHint: String {
        switch self {
        case .menstruation:
            return "Eisen und Flüssigkeit priorisieren."
        case .follicular:
            return "Protein und Energie für Aufbau nutzen."
        case .ovulation:
            return "Leistung unterstützen, genug Carbs einplanen."
        case .luteal:
            return "Regelmäßig essen, Magnesium und komplexe Carbs beachten."
        case .unknown:
            return "Ausgewogen essen und auf dein Energielevel achten."
        }
    }

    var baseMultiplier: Double {
        switch self {
        case .menstruation: return 0.90
        case .follicular: return 1.03
        case .ovulation: return 1.07
        case .luteal: return 0.95
        case .unknown: return 1.00
        }
    }
}

enum CycleSource: String, Codable, CaseIterable {
    case none
    case healthKit
    case manual
}

enum CycleCorrection: String, Codable, CaseIterable {
    case notStarted
    case startedEarlier
    case startedLater
    case confirmed
}

struct CycleState: Codable, Identifiable {
    var id: String = UUID().uuidString
    var source: CycleSource = .none
    var lastPeriodStart: Date? = nil
    var cycleLengthDays: Int = 28
    var periodLengthDays: Int = 5
    var confidence: Double = 0.35
    var notes: String = ""

    func currentPhase(on date: Date = Date()) -> CyclePhase {
        guard let lastPeriodStart else { return .unknown }

        let daysSince = Calendar.current.dateComponents([.day], from: lastPeriodStart, to: date).day ?? 0
        let dayInCycle = (daysSince % max(cycleLengthDays, 21)) + 1

        if dayInCycle <= periodLengthDays {
            return .menstruation
        } else if dayInCycle <= 13 {
            return .follicular
        } else if dayInCycle <= 15 {
            return .ovulation
        } else {
            return .luteal
        }
    }
}

struct CycleLearningProfile: Codable {
    var averageCycleLength: Int = 28
    var averagePeriodLength: Int = 5
    var lastConfirmedPeriodStart: Date? = nil
    var confidenceScore: Double = 0.35
}

