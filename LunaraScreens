// MARK: - Training

struct LunaraTrainingView: View {
    @EnvironmentObject private var store: LunaraStore
    @State private var showExercisePicker = false
    @State private var selectedExerciseID: String?
    @State private var restRemaining = 0
    @State private var restTimer: Timer?
    @State private var durationMinutes = 60
    @State private var showTemplateBuilder = false

    var body: some View {
        NavigationStack {
            ZStack {
                LunaraBackground()

                ScrollView {
                    VStack(spacing: 16) {
                        if let template = store.todaysTemplates.first, store.activeTemplateID == nil {
                            LunaraCard {
                                VStack(alignment: .leading, spacing: 12) {
                                    LunaraSectionTitle("Heute passt die Vorlage", subtitle: "Du kannst sie mit einem Tap laden")
                                    Text("\(template.emoji) \(template.name)")
                                        .foregroundStyle(.white)
                                        .font(.headline)
                                    Button("Vorlage laden") {
                                        store.loadTemplateIntoDraft(template)
                                    }
                                    .buttonStyle(LunaraPrimaryButton())
                                }
                            }
                        }

                        LunaraCard {
                            VStack(alignment: .leading, spacing: 12) {
                                LunaraSectionTitle("Training starten", subtitle: "Spontan oder mit Vorlage")
                                HStack {
                                    Button("Übung hinzufügen") { showExercisePicker = true }
                                        .buttonStyle(LunaraPrimaryButton())
                                    Button("Vorlagen") { showTemplateBuilder = true }
                                        .buttonStyle(LunaraSecondaryButton())
                                }
                                Text("Zyklus: \(store.currentPhase.emoji) \(store.currentPhase.title)")
                                    .foregroundStyle(.white)
                                    .font(.subheadline.bold())
                            }
                        }

                        if restRemaining > 0 {
                            LunaraCard {
                                VStack(alignment: .leading, spacing: 10) {
                                    LunaraSectionTitle("Pausentimer", subtitle: "Nächster Satz in")
                                    Text("\(restRemaining)s")
                                        .font(.system(size: 34, weight: .bold, design: .rounded))
                                        .foregroundStyle(.white)
                                    Button("Timer stoppen") {
                                        stopRestTimer()
                                    }
                                    .buttonStyle(LunaraSecondaryButton())
                                }
                            }
                        }

                        ForEach(store.draftLogs.indices, id: \.self) { idx in
                            exerciseDraftCard(for: idx)
                        }

                        Button {
                            store.finishTraining(durationMinutes: durationMinutes)
                        } label: {
                            Text("💜 Training beenden & speichern")
                        }
                        .buttonStyle(LunaraPrimaryButton())
                        .disabled(store.draftLogs.isEmpty)

                        Spacer(minLength: 80)
                    }
                    .padding()
                }
            }
            .navigationTitle("Training")
            .sheet(isPresented: $showExercisePicker) {
                LunaraExerciseLibraryView(selectionMode: true) { exercise in
                    store.addExerciseToDraft(exercise)
                    selectedExerciseID = exercise.id
                }
            }
            .sheet(isPresented: $showTemplateBuilder) {
                LunaraTemplateBuilderView()
            }
        }
    }

    @ViewBuilder
    private func exerciseDraftCard(for index: Int) -> some View {
        let log = store.draftLogs[index]
        let recommendation = store.recommendation(for: log.exerciseID)

        LunaraCard {
            VStack(alignment: .leading, spacing: 12) {
                HStack {
                    Text("\(log.icon) \(log.exerciseName)")
                        .font(.headline)
                        .foregroundStyle(.white)
                    Spacer()
                    Button {
                        store.removeExerciseFromDraft(log.id)
                    } label: {
                        Image(systemName: "trash")
                            .foregroundStyle(.red.opacity(0.9))
                    }
                }

                Text("Empfehlung: \(recommendation.weight, specifier: "%.1f") kg × \(recommendation.reps)")
                    .foregroundStyle(.white)
                Text(recommendation.note)
                    .font(.caption)
                    .foregroundStyle(Color.lunaraTextSoft.opacity(0.8))
                Text(recommendation.warning)
                    .font(.caption2)
                    .foregroundStyle(Color.lunaraTextSoft.opacity(0.6))

                HStack(spacing: 8) {
                    Stepper(
                        "kg \(String(format: "%.1f", log.sets.last?.weight ?? recommendation.weight))",
                        value: Binding(
                            get: { log.sets.last?.weight ?? recommendation.weight },
                            set: { _ in }
                        ),
                        in: 0...250,
                        step: 0.5
                    )
                    .labelsHidden()

                    Stepper(
                        "Wdh \(log.sets.last?.reps ?? recommendation.reps)",
                        value: Binding(
                            get: { log.sets.last?.reps ?? recommendation.reps },
                            set: { _ in }
                        ),
                        in: 1...30
                    )
                    .labelsHidden()
                }

                HStack(spacing: 8) {
                    Button("Satz +") {
                        let currentWeight = log.sets.last?.weight ?? recommendation.weight
                        let currentReps = log.sets.last?.reps ?? recommendation.reps
                        store.addSet(
                            to: log.id,
                            weight: currentWeight,
                            reps: currentReps,
                            rir: 2,
                            restSeconds: log.restSeconds
                        )
                        startRestTimer(seconds: log.restSeconds)
                    }
                    .buttonStyle(LunaraPrimaryButton())

                    Button("Zu leicht") { store.updateFeedback(exerciseID: log.exerciseID, feedback: .tooEasy) }
                        .buttonStyle(LunaraSecondaryButton())

                    Button("Zu hart") { store.updateFeedback(exerciseID: log.exerciseID, feedback: .tooHard) }
                        .buttonStyle(LunaraSecondaryButton())
                }

                if !log.sets.isEmpty {
                    VStack(alignment: .leading, spacing: 6) {
                        Text("Sätze")
                            .font(.caption.bold())
                            .foregroundStyle(Color.lunaraTextSoft.opacity(0.8))
                        ForEach(log.sets.indices, id: \.self) { s in
                            let set = log.sets[s]
                            Text("• \(set.weight, specifier: "%.1f") kg × \(set.reps) · RIR \(set.rir)")
                                .foregroundStyle(.white)
                                .font(.caption)
                        }
                    }
                }
            }
        }
    }

    private func startRestTimer(seconds: Int) {
        stopRestTimer()
        restRemaining = max(0, seconds)
        guard restRemaining > 0 else { return }

        restTimer = Timer.scheduledTimer(withTimeInterval: 1, repeats: true) { timer in
            if restRemaining <= 1 {
                restRemaining = 0
                timer.invalidate()
            } else {
                restRemaining -= 1
            }
        }
    }

    private func stopRestTimer() {
        restTimer?.invalidate()
        restTimer = nil
        restRemaining = 0
    }
}

// MARK: - Exercise Library

struct LunaraExerciseLibraryView: View {
    @EnvironmentObject private var store: LunaraStore
    @Environment(\.dismiss) private var dismiss

    var selectionMode: Bool = false
    var onSelect: ((Exercise) -> Void)? = nil

    @State private var searchText = ""
    @State private var selectedCategory: ExerciseCategory? = nil
    @State private var selectedMuscle: MuscleGroup? = nil
    @State private var selectedEquipment: EquipmentType? = nil
    @State private var showCustomExerciseSheet = false

    var filteredExercises: [Exercise] {
        store.exerciseLibrary.filter { exercise in
            let matchesSearch = searchText.isEmpty || exercise.name.localizedCaseInsensitiveContains(searchText)
            let matchesCategory = selectedCategory == nil || exercise.category == selectedCategory
            let matchesMuscle = selectedMuscle == nil || exercise.primaryMuscle == selectedMuscle || exercise.secondaryMuscles.contains(selectedMuscle!)
            let matchesEquipment = selectedEquipment == nil || exercise.equipment == selectedEquipment
            return matchesSearch && matchesCategory && matchesMuscle && matchesEquipment
        }
    }

    var body: some View {
        NavigationStack {
            ZStack {
                LunaraBackground()

                ScrollView {
                    VStack(spacing: 16) {
                        searchBar

                        filterSection

                        LunaraCard {
                            VStack(alignment: .leading, spacing: 10) {
                                HStack {
                                    LunaraSectionTitle("Übungen", subtitle: "\(filteredExercises.count) gefunden")
                                    Spacer()
                                    if store.subscriptionService.isPremiumActive() {
                                        Button("Custom") { showCustomExerciseSheet = true }
                                            .buttonStyle(LunaraSecondaryButton())
                                    }
                                }

                                LazyVGrid(columns: [GridItem(.adaptive(minimum: 150), spacing: 12)], spacing: 12) {
                                    ForEach(filteredExercises) { exercise in
                                        exerciseCard(exercise)
                                    }
                                }
                            }
                        }
                    }
                    .padding()
                }
            }
            .navigationTitle(selectionMode ? "Übung wählen" : "Übungen")
            .sheet(isPresented: $showCustomExerciseSheet) {
                LunaraCustomExerciseSheet()
            }
        }
    }

    private var searchBar: some View {
        LunaraCard {
            VStack(alignment: .leading, spacing: 10) {
                LunaraSectionTitle("Suche", subtitle: "Wie Lyfta, nur mit Lunara-Style")
                TextField("Übung suchen …", text: $searchText)
                    .textFieldStyle(.roundedBorder)
            }
        }
    }

    private var filterSection: some View {
        LunaraCard {
            VStack(alignment: .leading, spacing: 10) {
                LunaraSectionTitle("Filter", subtitle: "Muskel, Kategorie, Equipment")
                ScrollView(.horizontal, showsIndicators: false) {
                    HStack(spacing: 8) {
                        filterChip(title: "Alle", active: selectedCategory == nil) { selectedCategory = nil }
                        ForEach(ExerciseCategory.allCases) { cat in
                            filterChip(title: cat.title, active: selectedCategory == cat) {
                                selectedCategory = selectedCategory == cat ? nil : cat
                            }
                        }
                    }
                }
                ScrollView(.horizontal, showsIndicators: false) {
                    HStack(spacing: 8) {
                        filterChip(title: "Alle Muskeln", active: selectedMuscle == nil) { selectedMuscle = nil }
                        ForEach(MuscleGroup.allCases) { muscle in
                            filterChip(title: muscle.title, active: selectedMuscle == muscle) {
                                selectedMuscle = selectedMuscle == muscle ? nil : muscle
                            }
                        }
                    }
                }
                ScrollView(.horizontal, showsIndicators: false) {
                    HStack(spacing: 8) {
                        filterChip(title: "Alle Geräte", active: selectedEquipment == nil) { selectedEquipment = nil }
                        ForEach(EquipmentType.allCases) { equipment in
                            filterChip(title: equipment.title, active: selectedEquipment == equipment) {
                                selectedEquipment = selectedEquipment == equipment ? nil : equipment
                            }
                        }
                    }
                }
            }
        }
    }

    @ViewBuilder
    private func exerciseCard(_ exercise: Exercise) -> some View {
        let addAction = {
            if selectionMode {
                onSelect?(exercise)
                dismiss()
            } else {
                store.addExerciseToDraft(exercise)
            }
        }

        Button(action: addAction) {
            VStack(alignment: .leading, spacing: 8) {
                Text(exercise.icon)
                    .font(.title2)
                Text(exercise.name)
                    .font(.headline)
                    .foregroundStyle(.white)
                Text(exercise.primaryMuscle.title)
                    .font(.caption)
                    .foregroundStyle(Color.lunaraTextSoft.opacity(0.75))
                Text(exercise.equipment.title)
                    .font(.caption2)
                    .foregroundStyle(Color.lunaraTextSoft.opacity(0.55))
                Spacer(minLength: 0)
                Text(selectionMode ? "Hinzufügen" : "Zum Training")
                    .font(.caption.bold())
                    .foregroundStyle(Color.lunaraLavender)
            }
            .padding(12)
            .frame(maxWidth: .infinity, minHeight: 140, alignment: .leading)
            .background(Color.white.opacity(0.06))
            .clipShape(RoundedRectangle(cornerRadius: 18, style: .continuous))
        }
        .buttonStyle(.plain)
    }

    private func filterChip(title: String, active: Bool, action: @escaping () -> Void) -> some View {
        Button(action: action) {
            ToggleChip(title: title, active: active)
        }
        .buttonStyle(.plain)
    }
}

struct LunaraCustomExerciseSheet: View {
    @EnvironmentObject private var store: LunaraStore
    @Environment(\.dismiss) private var dismiss

    @State private var name = ""
    @State private var icon = "✨"
    @State private var primaryMuscle: MuscleGroup = .glutes
    @State private var category: ExerciseCategory = .compound
    @State private var equipment: EquipmentType = .dumbbell
    @State private var movement: MovementPattern = .hinge
    @State private var comparableIDs: Set<String> = []

    var body: some View {
        NavigationStack {
            Form {
                Section("Neue Übung") {
                    TextField("Name", text: $name)
                    TextField("Emoji", text: $icon)
                    Picker("Primäre Muskelgruppe", selection: $primaryMuscle) {
                        ForEach(MuscleGroup.allCases) { muscle in
                            Text(muscle.title).tag(muscle)
                        }
                    }
                    Picker("Kategorie", selection: $category) {
                        ForEach(ExerciseCategory.allCases) { cat in
                            Text(cat.title).tag(cat)
                        }
                    }
                    Picker("Equipment", selection: $equipment) {
                        ForEach(EquipmentType.allCases) { item in
                            Text(item.title).tag(item)
                        }
                    }
                    Picker("Bewegung", selection: $movement) {
                        ForEach(MovementPattern.allCases) { item in
                            Text(item.rawValue.capitalized).tag(item)
                        }
                    }
                }

                Section("Vergleichsübungen") {
                    ForEach(store.exerciseLibrary) { exercise in
                        Toggle(exercise.name, isOn: Binding(
                            get: { comparableIDs.contains(exercise.id) },
                            set: { isOn in
                                if isOn {
                                    comparableIDs.insert(exercise.id)
                                } else {
                                    comparableIDs.remove(exercise.id)
                                }
                            }
                        ))
                    }
                }

                Section {
                    Button("💜 Speichern") {
                        store.addCustomExercise(
                            name: name,
                            icon: icon.isEmpty ? "✨" : icon,
                            primaryMuscle: primaryMuscle,
                            category: category,
                            equipment: equipment,
                            movement: movement,
                            comparableExerciseIDs: Array(comparableIDs)
                        )
                        dismiss()
                    }
                    .disabled(name.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
                }
            }
            .navigationTitle("Custom Exercise")
        }
    }
}

