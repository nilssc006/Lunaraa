struct LunaraTemplateEditorView: View {
    @EnvironmentObject private var store: LunaraStore
    @Environment(\.dismiss) private var dismiss

    @State var template: TrainingTemplate
    @State private var showPicker = false

    var body: some View {
        NavigationStack {
            Form {
                Section("Vorlage") {
                    TextField("Name", text: $template.name)
                    TextField("Emoji", text: $template.emoji)
                    Stepper("Pausenzeit: \(template.defaultRestSeconds)s", value: $template.defaultRestSeconds, in: 30...300, step: 15)
                }

                Section("Wochentage") {
                    HStack {
                        ForEach(Weekday.allCases) { day in
                            Button {
                                if template.weekdayBindings.contains(day) {
                                    template.weekdayBindings.removeAll(where: { $0 == day })
                                } else {
                                    template.weekdayBindings.append(day)
                                }
                            } label: {
                                ToggleChip(title: day.title, active: template.weekdayBindings.contains(day))
                            }
                            .buttonStyle(.plain)
                        }
                    }
                }

                Section("Übungen") {
                    ForEach(template.plannedExercises) { item in
                        VStack(alignment: .leading, spacing: 8) {
                            Text("\(item.icon) \(item.exerciseName)")
                                .font(.headline)
                            Stepper("Sätze: \(item.targetSets)", value: binding(for: item.id, keyPath: \.targetSets), in: 1...10)
                            Stepper("Wdh: \(item.targetReps)", value: binding(for: item.id, keyPath: \.targetReps), in: 1...20)
                            Stepper("RIR: \(item.targetRIR)", value: binding(for: item.id, keyPath: \.targetRIR), in: 0...5)
                            Stepper("Pause: \(item.restSeconds)s", value: binding(for: item.id, keyPath: \.restSeconds), in: 30...300, step: 15)
                            Button("Entfernen") {
                                template.plannedExercises.removeAll { $0.id == item.id }
                            }
                            .foregroundStyle(.red)
                        }
                    }

                    Button("Übung hinzufügen") { showPicker = true }
                }

                Section {
                    Button("💜 Speichern") {
                        store.addTemplate(template)
                        dismiss()
                    }
                    .disabled(template.name.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
                }
            }
            .navigationTitle("Vorlage bearbeiten")
            .sheet(isPresented: $showPicker) {
                LunaraExerciseLibraryView(selectionMode: true) { exercise in
                    template.plannedExercises.append(
                        TemplateExercise(
                            exerciseID: exercise.id,
                            exerciseName: exercise.name,
                            icon: exercise.icon,
                            targetSets: 3,
                            targetReps: 8,
                            targetRIR: 2,
                            restSeconds: template.defaultRestSeconds
                        )
                    )
                }
            }
        }
    }

    private func binding<T>(for id: String, keyPath: WritableKeyPath<TemplateExercise, T>) -> Binding<T> {
        Binding(
            get: {
                guard let item = template.plannedExercises.first(where: { $0.id == id }) else {
                    fatalError("Template exercise not found")
                }
                return item[keyPath: keyPath]
            },
            set: { newValue in
                guard let index = template.plannedExercises.firstIndex(where: { $0.id == id }) else { return }
                template.plannedExercises[index][keyPath: keyPath] = newValue
            }
        )
    }
}

