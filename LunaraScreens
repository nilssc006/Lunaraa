            }
            .navigationTitle("Fortschritt")
        }
    }

    @ViewBuilder
    private var exerciseChart: some View {
        let points = store.sessionPoints(for: selectedExerciseID)

        if points.isEmpty {
            Text("Noch keine Daten für diese Übung.")
                .foregroundStyle(Color.lunaraTextSoft.opacity(0.8))
                .font(.subheadline)
        } else {
            Chart(points) { point in
                LineMark(
                    x: .value("Datum", point.date),
                    y: .value("Gewicht", point.weight)
                )
                .foregroundStyle(Color.lunaraPrimary)

                PointMark(
                    x: .value("Datum", point.date),
                    y: .value("Gewicht", point.weight)
                )
                .foregroundStyle(color(for: point.phase))
            }
            .frame(height: 220)
        }
    }

    private func color(for phase: CyclePhase) -> Color {
        switch phase {
        case .menstruation: return .gray.opacity(0.8)
        case .follicular: return .lunaraLavender
        case .ovulation: return .lunaraPink
        case .luteal: return .lunaraPrimary
        case .unknown: return .white.opacity(0.6)
        }
    }

    private func goalProgressText() -> String {
        let goal = store.monthlyGoal?.targetSessionsPerMonth ?? 10
        return "\(store.monthlySessionCount)/\(goal) Trainingseinheiten"
    }
}

// MARK: - Calendar

struct LunaraCalendarView: View {
    @EnvironmentObject private var store: LunaraStore

    private let calendar = Calendar.current

    var body: some View {
        NavigationStack {
            ZStack {
                LunaraBackground()

                ScrollView {
                    VStack(spacing: 16) {
                        LunaraCard {
                            VStack(alignment: .leading, spacing: 12) {
                                LunaraSectionTitle("Kalender", subtitle: "Trainingstage markiert")
                                monthGrid
                            }
                        }

                        LunaraCard {
                            VStack(alignment: .leading, spacing: 10) {
                                LunaraSectionTitle("Letzte Trainings", subtitle: "Chronologie")
                                ForEach(store.sessions.sorted(by: { $0.date > $1.date }).prefix(12)) { session in
                                    HStack {
                                        VStack(alignment: .leading) {
                                            Text("\(session.title)")
                                                .foregroundStyle(.white)
                                                .font(.headline)
                                            Text(session.date.formatted(date: .abbreviated, time: .omitted))
                                                .foregroundStyle(Color.lunaraTextSoft.opacity(0.7))
                                                .font(.caption)
                                        }
                                        Spacer()
                                        Text("💜 \(session.totalSets)")
                                            .foregroundStyle(.white)
                                    }
                                }
                            }
                        }
                    }
                    .padding()
                }
            }
            .navigationTitle("Kalender")
        }
    }

    private var monthGrid: some View {
        let days = daysInCurrentMonth()
        let trainingDates = Set(store.sessions.map { calendar.startOfDay(for: $0.date) })

        return VStack(spacing: 10) {
            let weekdays = ["Mo", "Di", "Mi", "Do", "Fr", "Sa", "So"]
            HStack {
                ForEach(weekdays, id: \.self) { day in
                    Text(day)
                        .font(.caption.bold())
                        .foregroundStyle(Color.lunaraTextSoft.opacity(0.7))
                        .frame(maxWidth: .infinity)
                }
            }

            LazyVGrid(columns: Array(repeating: GridItem(.flexible(), spacing: 8), count: 7), spacing: 8) {
                ForEach(days, id: \.self) { date in
                    if let date {
                        let hasTraining = trainingDates.contains(calendar.startOfDay(for: date))
                        VStack(spacing: 4) {
                            Text("\(calendar.component(.day, from: date))")
                                .foregroundStyle(.white)
                                .font(.subheadline.bold())
                            Circle()
                                .fill(hasTraining ? Color.lunaraPrimary : Color.white.opacity(0.08))
                                .frame(width: 8, height: 8)
                        }
                        .frame(maxWidth: .infinity, minHeight: 44)
                        .padding(.vertical, 6)
                        .background(Color.white.opacity(0.05))
                        .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                    } else {
                        Color.clear
                            .frame(height: 44)
                    }
                }
            }
        }
    }

    private func daysInCurrentMonth() -> [Date?] {
        guard let interval = calendar.dateInterval(of: .month, for: Date()) else { return [] }
        let firstWeekday = calendar.component(.weekday, from: interval.start)
        let startOffset = (firstWeekday + 5) % 7

        let numberOfDays = calendar.range(of: .day, in: .month, for: Date())?.count ?? 30
        var result: [Date?] = Array(repeating: nil, count: startOffset)

        for day in 0..<numberOfDays {
            let date = calendar.date(byAdding: .day, value: day, to: interval.start)
            result.append(date)
        }
        while result.count % 7 != 0 { result.append(nil) }
        return result
    }
}

