// MARK: - Subscription

struct LunaraSubscriptionView: View {
    @EnvironmentObject private var store: LunaraStore
    @Environment(\.dismiss) private var dismiss

    @State private var inviteInput = ""
    @State private var statusMessage: String = ""

    var body: some View {
        NavigationStack {
            Form {
                Section("Status") {
                    Text("Aktuell: \(store.subscriptionService.state.status.rawValue.capitalized)")
                    if let trialEndsAt = store.subscriptionService.state.trialEndsAt {
                        Text("Trial bis: \(trialEndsAt.formatted(date: .abbreviated, time: .omitted))")
                    }
                    Text("Rabatt: \(store.subscriptionService.state.discountPercent)%")
                }

                Section("Abo") {
                    Button("Monatlich freischalten (StoreKit)") {
                        Task {
                            await store.subscriptionService.loadProducts()
                            if let product = store.subscriptionService.products.first(where: { $0.id == store.subscriptionService.monthlyProductID }) {
                                await store.subscriptionService.purchase(product)
                                store.save()
                            } else {
                                store.subscriptionService.activateManualPremiumPreview()
                                store.save()
                            }
                        }
                    }

                    Button("Jährlich freischalten (StoreKit)") {
                        Task {
                            await store.subscriptionService.loadProducts()
                            if let product = store.subscriptionService.products.first(where: { $0.id == store.subscriptionService.yearlyProductID }) {
                                await store.subscriptionService.purchase(product)
                                store.save()
                            } else {
                                store.subscriptionService.activateManualPremiumPreview()
                                store.save()
                            }
                        }
                    }

                    Button("Restore") {
                        Task {
                            await store.subscriptionService.restore()
                            store.save()
                        }
                    }
                }

                Section("Freunde einladen") {
                    Text("Dein Code: \(store.subscriptionService.shareCode())")
                    ShareLink(item: store.shareInviteURL(), preview: SharePreview("Lunara Invite")) {
                        Text("Code teilen")
                    }

                    TextField("Invite-Code eingeben", text: $inviteInput)
                    Button("Code einlösen") {
                        let success = store.claimInvite(code: inviteInput)
                        statusMessage = success ? "💜 Einladung akzeptiert" : "Code ungültig"
                    }
                    if !statusMessage.isEmpty {
                        Text(statusMessage)
                    }
                }

                Section("Hinweis") {
                    Text("Referral-Logik ist lokal aktiv. Für echte Cross-Device-Verifizierung brauchst du später einen kleinen Backend-Service.")
                }
            }
            .navigationTitle("Abo")
        }
    }
}

